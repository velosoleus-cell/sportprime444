<!DOCTYPE html>
<html>
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/nav') %>

<section>
  <div class="container" style="max-width:560px;">
    <div class="invoice-box" style="text-align:center;padding:50px 34px;">
      <% if (order.paymentStatus === 'paid') { %>
        <div style="font-size:44px;margin-bottom:14px;">✅</div>
        <h2 style="margin-bottom:10px;color:#111;">Payment Received — Order Confirmed!</h2>
        <p style="color:#555;margin:0 auto 22px;">
          Thanks, <%= order.customer.name %>. Your payment went through and your order is awaiting review.
          Our team will contact you shortly, and your tracking ID will be issued once the order is processed.
        </p>
      <% } else { %>
        <div style="font-size:44px;margin-bottom:14px;">⏳</div>
        <h2 style="margin-bottom:10px;color:#111;">Order Received — Payment Pending</h2>
        <p style="color:#555;margin:0 auto 22px;">
          Thanks, <%= order.customer.name %>. We're still confirming your payment with Safepay — this page will
          usually update within a few seconds of a successful payment. If this persists, please contact us with your Order ID.
        </p>
      <% } %>
      <div class="invoice-track" style="justify-content:center;">
        <span>Order ID: <b><%= order.orderCode %></b></span>
        <span>Total: <b><%= money(order.total) %></b></span>
      </div>
      <p style="color:#888;font-size:12.5px;margin-top:20px;">Save your Order ID — you can use it on the "Track Order" page to check your status anytime.</p>
      <a href="/shop" class="btn" style="margin-top:20px;">Continue Shopping</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
