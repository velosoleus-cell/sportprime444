<!DOCTYPE html>
<html>
<head><%- include('../partials/head') %></head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;">
  <div class="form-panel" style="max-width:380px;width:100%;">
    <div class="brand" style="justify-content:center;margin-bottom:6px;">
      <img src="/images/logo.png" style="width:40px;height:40px;"><span class="name">SPORT<span>PRIME</span></span>
    </div>
    <h3 style="text-align:center;color:var(--text-faint);font-size:13px;letter-spacing:.1em;margin:0 0 26px;font-weight:600;text-transform:uppercase;">Admin Panel Login</h3>

    <% if (error) { %><div class="alert"><%= error %></div><% } %>

    <form action="/admin/login" method="post">
      <div class="field"><label>Password</label><input type="password" name="password" autofocus required></div>
      <button type="submit" class="btn" style="width:100%;justify-content:center;">Login</button>
    </form>
    <p style="font-size:12px;color:var(--text-faint);margin-top:14px;">Default password: <b>sportprime2026</b> (change it under Settings after logging in)</p>
    <p style="font-size:12px;margin-top:16px;"><a href="/" style="color:var(--text-dim);">&larr; Back to store</a></p>
  </div>
</div>
</body>
</html>
