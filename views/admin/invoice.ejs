<!DOCTYPE html>
<html>
<head><%- include('../partials/head') %></head>
<body>
<div class="admin-shell">
  <%- include('../partials/admin-sidebar') %>

  <div class="admin-main">
    <div class="admin-top">
      <div><h2>Invoice</h2><p>Order <%= order.orderCode %></p></div>
      <div style="display:flex;gap:10px;">
        <button onclick="window.print()" class="btn ghost">Print Invoice</button>
        <a href="/admin/orders/<%= order._id %>/invoice/pdf" class="btn">Download PDF</a>
        <a href="/admin/orders" class="btn ghost">Back to Orders</a>
      </div>
    </div>

    <div class="invoice-box">
      <div class="invoice-head">
        <div style="display:flex;align-items:center;gap:10px;">
          <img src="/images/logo.png">
          <div><b style="font-family:'Rajdhani',sans-serif;font-size:18px;">SPORT PRIME</b><div style="font-size:11px;color:#777;">Performance Sportswear</div></div>
        </div>
        <div style="text-align:right;font-size:13px;">
          <div><b>Invoice</b></div>
          <div><%= new Date(order.date).toLocaleDateString() %>, <%= new Date(order.date).toLocaleTimeString() %></div>
        </div>
      </div>

      <p style="font-size:13px;color:#555;">
        <b>Bill To:</b> <%= order.customer.name %> · <%= order.customer.phone %>
        <% if (order.customer.email) { %> · <%= order.customer.email %><% } %>
      </p>
      <p style="font-size:13px;color:#555;margin-top:4px;"><b>Ship To:</b> <%= order.customer.address %></p>

      <div class="invoice-track">
        <span>Order ID: <b><%= order.orderCode %></b></span>
        <span>Tracking ID: <b><%= order.trackingId || 'Not yet assigned' %></b></span>
        <span>Payment: <b><%= order.paymentMethod %> (<%= order.paymentStatus === 'paid' ? 'Paid' : 'Unpaid' %>)</b></span>
        <span>Status: <b><%= order.status %></b></span>
      </div>

      <table>
        <thead><tr><th>Item</th><th>Category</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead>
        <tbody>
          <% order.items.forEach(it => { %>
            <tr>
              <td><%= it.name %><% if (it.size) { %> (<%= it.size %>)<% } %></td>
              <td><%= categoryName(it.category) %></td>
              <td><%= it.qty %></td>
              <td><%= money(it.price) %></td>
              <td><%= money(it.price * it.qty) %></td>
            </tr>
          <% }) %>
          <% if (order.discount > 0) { %>
            <tr>
              <td colspan="4" style="text-align:right;color:#888;">Sale Discount</td>
              <td style="color:#e2001a;">-<%= money(order.discount) %></td>
            </tr>
          <% } %>
          <tr style="font-weight:700;font-size:15px;border-top:2px solid #111;">
            <td colspan="4" style="text-align:right;">Total Payable</td>
            <td><%= money(order.total) %></td>
          </tr>
        </tbody>
      </table>

      <p style="margin-top:20px;font-size:12px;color:#666;text-align:center;">Thank you for shopping with Sport Prime. Track your order anytime using your Order ID or Tracking ID.</p>
    </div>
  </div>
</div>
</body>
</html>
