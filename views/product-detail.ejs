<!DOCTYPE html>
<html>
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/nav') %>

<section>
  <div class="container" style="max-width:900px;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;">
      <div class="prod-media" style="height:320px;">
        <% if (product.image) { %>
          <img src="/uploads/<%= product.image %>" alt="<%= product.name %>">
        <% } else { %>
          <span class="cat-icon-svg"><%- categoryIconSvg(product.category, 90) %></span>
        <% } %>
      </div>
      <div>
        <span class="prod-cat"><%= categoryName(product.category) %></span>
        <h1 style="font-size:28px;margin:8px 0 14px;"><%= product.name %></h1>
        <div class="prod-price-row" style="margin-bottom:18px;">
          <span class="prod-price sale" style="font-size:24px;"><%= money(salePriceValue) %></span>
          <% if (settings.saleLive) { %><span class="prod-old-price"><%= money(product.price) %></span><% } %>
        </div>
        <p style="color:var(--text-dim);font-size:14.5px;margin-bottom:20px;"><%= product.description %></p>

        <% if (error) { %><div class="alert"><%= error %></div><% } %>

        <form action="/cart/add" method="post">
          <input type="hidden" name="productId" value="<%= product._id %>">

          <% if (product.sizes && product.sizes.length) { %>
            <div class="field">
              <label>Select Size</label>
              <select name="size">
                <% product.sizes.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
              </select>
            </div>
          <% } %>

          <div class="field" style="max-width:140px;">
            <label>Quantity</label>
            <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>">
          </div>

          <p style="font-size:12.5px;color:var(--text-faint);margin-bottom:16px;">
            <%= product.stock > 0 ? product.stock + ' in stock' : 'Out of stock' %>
          </p>

          <button type="submit" class="btn" <%= product.stock <= 0 ? 'disabled' : '' %>>Add To Cart</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
